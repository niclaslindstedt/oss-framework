{
  "name": "@niclaslindstedt/oss-framework",
  "version": "0.1.0",
  "description": "Shared React components, hooks and utilities for building local-first PWAs — storage backends, encryption, themes, folders and namespaces extracted from the notes and checklist apps.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Niclas Lindstedt <niclas@agilator.se>",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "demo"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./changelog": {
      "types": "./dist/changelog/index.d.ts",
      "import": "./dist/changelog/index.js",
      "require": "./dist/changelog/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js",
      "require": "./dist/logging/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "clone-apps": "node .agent/skills/find-refactor-candidates/scripts/clone-apps.mjs",
    "candidates": "node .agent/skills/find-refactor-candidates/scripts/similarity.mjs",
    "bump": "node scripts/release/compute-bump.mjs",
    "changelog": "node scripts/release/collate-changelog.mjs",
    "dev:demo": "npm run dev --workspace demo",
    "build:demo": "npm run build --workspace demo",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
