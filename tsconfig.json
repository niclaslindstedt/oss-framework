{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "skipLibCheck": true,

    // tsup's .d.ts build injects a `baseUrl`, which TypeScript 6 deprecates;
    // silence it until tsup stops setting it (removed for good in TS 7).
    "ignoreDeprecations": "6.0",

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // The release-tooling unit test imports the dogfooded `.mjs` scripts under
    // scripts/release/; allow JS so those resolve (their exports type as
    // `any`; `checkJs` stays off, so the scripts aren't type-checked here).
    "allowJs": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,

    // `node` so the test suite can read fixtures via `node:fs`; the library
    // source stays browser-targeted through `lib` above (it imports no Node
    // built-ins, and the tsup build would surface any that slipped in).
    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "tests"]
}
